# Google OAuth — client de type « Application Web »
# URI de redirection autorisée :
#   https://rescrit-echo.theolannoye.fr/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback  (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optionnel : fallback serveur (sinon chaque utilisateur connecte son compte via l’UI)
# GOOGLE_REFRESH_TOKEN=

# Dossier Drive parent (contient les dossiers YYYY) — optionnel si inaccessible
GOOGLE_DRIVE_PARENT_FOLDER_ID=1uKyNWqsgBbzCEcpgHtw9ayNtCCt8eh

# Si le compte ne voit pas les parents (drive partagé) : ID du dossier année (ex. 2026)
# GOOGLE_DRIVE_YEAR_FOLDER_ID=

# Même valeur que passwordHash dans auth-config.js (protège les API)
AUTH_PASSWORD_HASH=

# Secret pour chiffrer le cookie OAuth (générez une chaîne aléatoire longue)
SESSION_SECRET=
